<Window
    x:Class="PuntoVenta.Views.EditProductWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Modificar Producto">

    <Grid>
        <!-- Fondo oscuro degradado -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2F3542" Offset="0.00"/>
                <GradientStop Color="#1F2937" Offset="0.45"/>
                <GradientStop Color="#111827" Offset="1.00"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Luces decorativas -->
        <Canvas>
            <Ellipse Width="420"
                     Height="420"
                     Fill="#1838BDF8"
                     Canvas.Left="-120"
                     Canvas.Top="-90"/>

            <Ellipse Width="360"
                     Height="360"
                     Fill="#2022D3EE"
                     Canvas.Left="870"
                     Canvas.Top="90"/>

            <Ellipse Width="260"
                     Height="260"
                     Fill="#18FFFFFF"
                     Canvas.Left="520"
                     Canvas.Top="420"/>
        </Canvas>

        <!-- Tarjeta principal -->
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center">

            <Border Width="560"
                    Height="620"
                    Background="#55FFFFFF"
                    CornerRadius="28"
                    BorderBrush="#B8FFFFFF"
                    BorderThickness="1.5"
                    Padding="35"
                    Margin="0,45,0,0">

                <StackPanel Spacing="13"
                            VerticalAlignment="Center">

                    <TextBlock Text="Modificar Producto"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,8"/>

                    <!-- Nombre -->
                    <Border CornerRadius="16"
                            Background="#E9EEF5"
                            Height="48">
                        <TextBox x:Name="NameBox"
                                 PlaceholderText="Nombre"
                                 MaxLength="50"
                                 Background="Transparent"
                                 Height="24"
                                 MaxWidth="450"
                                 Padding="14,0,14,0"
                                 BorderThickness="0"
                                 FontSize="15"
                                 VerticalContentAlignment="Center"/>
                    </Border>

                    <!-- Marca -->
                    <Border CornerRadius="16"
                            Background="#E9EEF5"
                            Height="44"
>
                        <TextBox x:Name="BrandBox"
                                 PlaceholderText="Marca"
                                 MaxLength="30"
                                 Background="Transparent"
                                 Height="24"
                                 MaxWidth="450"
                                 Padding="14,0,14,0"
                                 BorderThickness="0"
                                 FontSize="15"
                                 VerticalContentAlignment="Center"/>
                    </Border>

                    <!-- Descripción -->
                    <Border CornerRadius="16"
                            Background="#E9EEF5"
                            Height="44">
                        <TextBox x:Name="DescBox"
                                 PlaceholderText="Descripción"
                                 MaxLength="200"
                                 Background="Transparent"
                                 Height="24"
                                 MaxWidth="450"
                                 Padding="14,0,14,0"
                                 BorderThickness="0"
                                 FontSize="15"
                                 VerticalContentAlignment="Center"/>
                    </Border>

                    <!-- Costo -->
                    <Border CornerRadius="16"
                            Background="#E9EEF5"
                            Height="44">
                        <TextBox x:Name="CostBox"
                                 PlaceholderText="Costo"
                                 BeforeTextChanging="OnlyNumbersDecimal_BeforeTextChanging"
                                 Background="Transparent"
                                 Height="24"
                                 MaxWidth="450"
                                 Padding="14,0,14,0"
                                 BorderThickness="0"
                                 FontSize="15"
                                 VerticalContentAlignment="Center"/>
                    </Border>

                    <!-- Precio venta -->
                    <Border CornerRadius="16"
                            Background="#E9EEF5"
                            Height="44">
                        <TextBox x:Name="PriceBox"
                                 PlaceholderText="Precio venta (con IVA)"
                                 BeforeTextChanging="OnlyNumbersDecimal_BeforeTextChanging"
                                 Background="Transparent"
                                 Height="24"
                                 MaxWidth="450"
                                 Padding="14,0,14,0"
                                 BorderThickness="0"
                                 FontSize="15"
                                 VerticalContentAlignment="Center"/>
                    </Border>

                    <!-- Existencias -->
                    <Border CornerRadius="16"
                            Background="#E9EEF5"
                            Height="44">
                        <TextBox x:Name="StockBox"
                                 PlaceholderText="Existencias"
                                 BeforeTextChanging="OnlyNumbers_BeforeTextChanging"
                                 Background="Transparent"
                                 Height="24"
                                 MaxWidth="450"
                                 Padding="14,0,14,0"
                                 BorderThickness="0"
                                 FontSize="15"
                                 VerticalContentAlignment="Center"/>
                    </Border>

                    <!-- Imagen -->
                    <Border CornerRadius="16"
                            Background="#E9EEF5"
                            Height="44">
                        <TextBox x:Name="ImageBox"
                                 PlaceholderText="Imagen seleccionada"
                                 IsReadOnly="True"
                                 Background="Transparent"
                                 Height="24"
                                 MaxWidth="450"
                                 Padding="14,0,14,0"
                                 BorderThickness="0"
                                 FontSize="15"
                                 VerticalContentAlignment="Center"/>
                    </Border>

                    <!-- Botones -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="14"
                                HorizontalAlignment="Center"
                                Margin="0,12,0,0">

                        <Button Content="Seleccionar Imagen"
                                Width="210"
                                Height="46"
                                Background="#38BDF8"
                                Foreground="White"
                                FontSize="15"
                                FontWeight="SemiBold"
                                CornerRadius="14"
                                Click="SelectImage_Click"/>

                        <Button Content="Guardar Cambios"
                                Width="210"
                                Height="46"
                                Background="#0EA5E9"
                                Foreground="White"
                                FontSize="15"
                                FontWeight="SemiBold"
                                CornerRadius="14"
                                Click="Save_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- Icono circular arriba -->
            <Grid Width="110"
                  Height="110"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Top">

                <Ellipse Fill="#38BDF8"
                         Stroke="#AEEBFF"
                         StrokeThickness="3"/>

                <FontIcon Glyph="&#xE70F;"
                          FontFamily="Segoe MDL2 Assets"
                          FontSize="48"
                          Foreground="White"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
