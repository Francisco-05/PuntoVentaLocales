<Page
    x:Class="PuntoVenta.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#102A2F">

    <Grid>

        <!-- FONDO PRINCIPAL -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#102A2F" Offset="0"/>
                <GradientStop Color="#1F4E5F" Offset="0.45"/>
                <GradientStop Color="#F26B5E" Offset="0.82"/>       
                <GradientStop Color="#F4D06F" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- FIGURAS DECORATIVAS -->
        <Canvas Opacity="0.35">
            <Ellipse Width="520"
                     Height="520"
                     Fill="#33FFFFFF"
                     Canvas.Left="-160"
                     Canvas.Top="-120"/>

            <Ellipse Width="420"
                     Height="420"
                     Fill="#3337C6D0"
                     Canvas.Left="850"
                     Canvas.Top="80"/>

            <Ellipse Width="350"
                     Height="350"
                     Fill="#33F4D06F"
                     Canvas.Left="180"
                     Canvas.Top="470"/>

            <Ellipse Width="300"
                     Height="300"
                     Fill="#33F26B5E"
                     Canvas.Left="1050"
                     Canvas.Top="480"/>
        </Canvas>

        <!-- TARJETA CENTRAL -->
        <Border Width="760"
                Height="480"
                Background="#D9FFF8EF"
                CornerRadius="32"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#70FFFFFF"
                BorderThickness="1.5">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LADO IZQUIERDO -->
                <Grid Grid.Column="0"
                      Background="#102A2F">

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="18">

                        <Grid Width="135"
                              Height="135">

                            <Ellipse Fill="#F26B5E"
                                     Stroke="#F4D06F"
                                     StrokeThickness="3"/>

                            <FontIcon Glyph="&#xE77B;"
                                      FontFamily="Segoe MDL2 Assets"
                                      FontSize="60"
                                      Foreground="White"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="ClickCompra"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Sistema de punto de venta"
                                   FontSize="15"
                                   Foreground="#E8FFFA"
                                   TextAlignment="Center"
                                   Width="200"/>
                    </StackPanel>
                </Grid>

                <!-- FORMULARIO -->
                <Grid Grid.Column="1"
                      Padding="45">

                    <StackPanel VerticalAlignment="Center"
                                Spacing="16">

                        <TextBlock Text="Bienvenido(a)"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="#102A2F"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Inicia sesión para continuar"
                                   FontSize="15"
                                   Foreground="#42666D"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>

                        <!-- USERNAME -->
                        <Border Background="White"
                                CornerRadius="20"
                                Height="48"
                                BorderBrush="#37C6D0"
                                BorderThickness="1.5"
                                Padding="2,0">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <FontIcon Glyph="&#xE77B;"
                                          FontFamily="Segoe MDL2 Assets"
                                          FontSize="17"
                                          Foreground="#1F4E5F"
                                          VerticalAlignment="Center"/>

                                <TextBox x:Name="UsernameBox"
                                         Height="24"
                                         Grid.Column="1"
                                         PlaceholderText="Username"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="#102A2F"
                                         PlaceholderForeground="#7A8B90"
                                         VerticalContentAlignment="Center"
                                         FontSize="15"
                                         MaxLength="30"
                                         Padding="35,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- PASSWORD -->
                        <Border Background="White"
                                CornerRadius="20"
                                Height="48"
                                BorderBrush="#37C6D0"
                                BorderThickness="1.5"
                                Padding="2,0">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <FontIcon Glyph="&#xE72E;"
                                          FontFamily="Segoe MDL2 Assets"
                                          FontSize="17"
                                          Foreground="#1F4E5F"
                                          VerticalAlignment="Center"/>

                                <PasswordBox x:Name="PasswordBox"
                                             Height="24"
                                             Grid.Column="1"
                                             PlaceholderText="Password"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="#102A2F"
                                             VerticalContentAlignment="Center"
                                             FontSize="15"
                                             MaxLength="12"
                                             Padding="35,0,0,0"/>
                                            
                            </Grid>
                        </Border>

                        <!-- BOTÓN LOGIN -->
                        <Button Content="Login"
                                Width="170"
                                Height="45"
                                Background="#F26B5E"
                                Foreground="White"
                                FontWeight="SemiBold"
                                FontSize="16"
                                BorderThickness="0"
                                CornerRadius="20"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0"
                                Click="Login_Click"/>

                        <!-- MENSAJE DE ERROR -->
                        <TextBlock x:Name="ErrorText"
                                   Text=""
                                   Foreground="#B91C1C"
                                   FontSize="13"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>