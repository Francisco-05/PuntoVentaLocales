<Page
    x:Class="PuntoVenta.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F5F6FA">
        <Border 
            Width="400"
            Padding="30"
            Background="White"
            CornerRadius="15"
            VerticalAlignment="Center"
            HorizontalAlignment="Center">

            <StackPanel Spacing="15">

                <TextBlock 
                    Text="Iniciar Sesión"
                    FontSize="28"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"/>

                <TextBox 
                    x:Name="UsernameBox"
                    PlaceholderText="Usuario"
                    Height="45"
                    FontSize="16"
                    CornerRadius="8"
                    Padding="50,10,45,10"/>

                <PasswordBox 
                    x:Name="PasswordBox"
                    PlaceholderText="Contraseña"
                    Height="45"
                    FontSize="16"
                    CornerRadius="8"
                    Padding="50,10,45,10"/>
                
                <Button 
                    Content="Entrar"
                    Height="45"
                    FontSize="16"
                    Background="#4F46E5"
                    Foreground="White"
                    CornerRadius="8"
                    Click="Login_Click"/>

                <TextBlock 
                    x:Name="ErrorText"
                    Foreground="Red"
                    HorizontalAlignment="Center"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>