<Page
    x:Class="PuntoVenta.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

    <Grid>
        <!-- FONDO -->
        <Grid.Background>
            <SolidColorBrush Color="Black"/>
        </Grid.Background>

        <!-- EFECTO DECORATIVO DE FONDO -->
        <Canvas>
            <Ellipse Width="500"
                     Height="500"
                     Fill="#2200FF88"
                     Canvas.Left="480"
                     Canvas.Top="-120"/>

            <Ellipse Width="600"
                     Height="600"
                     Fill="#220066FF"
                     Canvas.Left="-180"
                     Canvas.Top="180"/>

            <Ellipse Width="450"
                     Height="450"
                     Fill="#1800FF44"
                     Canvas.Left="250"
                     Canvas.Top="50"/>
        </Canvas>

        <!-- TARJETA CENTRAL -->
        <Border Width="600"
                Height="320"
                Background="#CC1A1A1A"
                CornerRadius="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#33FFFFFF"
                BorderThickness="1">

            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="18"
                        Width="500">

                <TextBlock Text="WELCOM TO ClickCompra 🛒"
                           Foreground="White"
                           FontSize="34"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,10"/>

                <!-- USERNAME -->
                <Border Background="#FF8A8A8A"
                        CornerRadius="20"
                        Height="45"
                        Padding="15,0">
                    <TextBox x:Name="UsernameBox"
                             PlaceholderText="Username"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="White"
                             PlaceholderForeground="#FFE5E5E5"
                             VerticalContentAlignment="Center"
                             FontSize="14"/>
                </Border>

                <!-- PASSWORD -->
                <Border Background="#FF8A8A8A"
                        CornerRadius="20"
                        Height="45"
                        Padding="15,0">
                    <PasswordBox x:Name="PasswordBox"
                                 PlaceholderText="Password"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="White"
                                 VerticalContentAlignment="Center"
                                 FontSize="14"/>
                </Border>

                <!-- BOTON LOGIN -->
                <Button Content="Login"
                        Width="95"
                        Height="38"
                        Background="#FF7A7A7A"
                        Foreground="White"
                        BorderThickness="0"
                        CornerRadius="18"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,0"
                        Click="Login_Click"/>

                <Button 
                    Content="Administrador"
                    Height="45"
                    FontSize="16"
                    FontFamily="Arial"
                    Background="WhiteSmoke"
                    Foreground="Black"
                    CornerRadius="8"
                    Padding="20,10,20,10"
                    HorizontalAlignment="Center"
                    Click="AdminLogin_Click"/>

                <Button 
                    Content="Empleado"
                    Height="45"
                    FontSize="16"
                    FontFamily="Arial"
                    Background="WhiteSmoke"
                    Foreground="Black"
                    CornerRadius="8"
                    Padding="20,10,20,10"
                    HorizontalAlignment="Center"
                    Click="EmployeeLogin_Click"/>

                <!-- MENSAJE DE ERROR -->
                <TextBlock x:Name="ErrorText"
                           Text=""
                           Foreground="DarkRed"
                           FontSize="13"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>