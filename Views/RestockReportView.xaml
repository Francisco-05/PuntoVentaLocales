<Page
    x:Class="PuntoVenta.Views.RestockReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <!-- Fondo verde degradado -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#052E1A" Offset="0.00"/>
                <GradientStop Color="#064E3B" Offset="0.35"/>
                <GradientStop Color="#047857" Offset="0.70"/>
                <GradientStop Color="#10B981" Offset="1.00"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Figuras decorativas -->
        <Canvas>
            <Ellipse Width="430"
                     Height="430"
                     Fill="#2200FFAA"
                     Canvas.Left="-130"
                     Canvas.Top="-100"/>

            <Ellipse Width="360"
                     Height="360"
                     Fill="#22FFFFFF"
                     Canvas.Left="930"
                     Canvas.Top="40"/>

            <Ellipse Width="300"
                     Height="300"
                     Fill="#1834D399"
                     Canvas.Left="120"
                     Canvas.Top="520"/>

            <Ellipse Width="280"
                     Height="280"
                     Fill="#1622C55E"
                     Canvas.Left="600"
                     Canvas.Top="220"/>
        </Canvas>

        <Grid Padding="35">

            <!-- Tarjeta principal -->
            <Border Background="#35FFFFFF"
                    CornerRadius="28"
                    BorderBrush="#60FFFFFF"
                    BorderThickness="1.2"
                    Padding="28">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Encabezado -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Reporte de reabastecimientos"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock Text="Consulta los movimientos de inventario y ajustes de existencias"
                                       FontSize="14"
                                       Foreground="#DDFCEB"
                                       Margin="0,5,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Volver"
                                HorizontalAlignment="Right"
                                Background="#EF4444"
                                Foreground="White"
                                Padding="24,11"
                                FontWeight="SemiBold"
                                Click="Back_Click"
                                VerticalAlignment="Top"
                                MinWidth="110"/>
                    </Grid>

                    <!-- Filtros -->
                    <Border Grid.Row="1"
                            Background="#25FFFFFF"
                            CornerRadius="22"
                            Padding="20"
                            Margin="0,25,0,18">

                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Desde -->
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="Desde"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>

                                <Border Background="#F0FDF4"
                                        CornerRadius="16"
                                        Padding="10,4">
                                    <CalendarDatePicker x:Name="StartDate"
                                                        Width="180"
                                                        Background="Transparent"
                                                        BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Hasta -->
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="Hasta"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>

                                <Border Background="#F0FDF4"
                                        CornerRadius="16"
                                        Padding="10,4">
                                    <CalendarDatePicker x:Name="EndDate"
                                                        Width="180"
                                                        Background="Transparent"
                                                        BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Tipo movimiento -->
                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="Tipo movimiento"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>

                                <Border Background="#F0FDF4"
                                        CornerRadius="16"
                                        Padding="10,2">
                                    <ComboBox x:Name="MovementFilter"
                                              Width="200"
                                              Background="Transparent"
                                              BorderThickness="0">

                                        <ComboBoxItem Content="Todos"
                                                      IsSelected="True"/>

                                        <ComboBoxItem Content="Reabastecimiento"/>

                                        <ComboBoxItem Content="Ajuste"/>
                                    </ComboBox>
                                </Border>
                            </StackPanel>

                            <!-- Botón filtrar -->
                            <StackPanel Grid.Column="3"
                                        VerticalAlignment="Bottom">

                                <Button Content="Filtrar"
                                        Background="#16A34A"
                                        Foreground="White"
                                        Padding="26,12"
                                        FontWeight="SemiBold"
                                        Click="Filter_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Lista -->
                    <ListView x:Name="RestockList"
                              Grid.Row="2"
                              Background="Transparent"
                              BorderThickness="0"
                              Margin="0,5,0,0">

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,14"/>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate>

                                <Border Background="#ECFDF5"
                                        CornerRadius="22"
                                        Padding="18"
                                        BorderBrush="#A7F3D0"
                                        BorderThickness="1">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Información -->
                                        <StackPanel Spacing="8">

                                            <TextBlock Text="{Binding Producto}"
                                                       FontSize="22"
                                                       FontWeight="Bold"
                                                       Foreground="#064E3B"/>

                                            <TextBlock FontSize="13"
                                                       Foreground="#6B7280">
                                                <Run Text="Fecha: "/>
                                                <Run Text="{Binding FechaModificacion}"/>
                                            </TextBlock>

                                            <Border Background="#DCFCE7"
                                                    CornerRadius="12"
                                                    Padding="10,6"
                                                    HorizontalAlignment="Left">

                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="#047857">
                                                    <Run Text="Movimiento: "/>
                                                    <Run Text="{Binding TipoMovimiento}"/>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>

                                        <!-- Existencias -->
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    Spacing="16"
                                                    VerticalAlignment="Center">

                                            <Border Background="White"
                                                    CornerRadius="16"
                                                    Padding="18,12"
                                                    MinWidth="85">
                                                <StackPanel>
                                                    <TextBlock Text="Inicial"
                                                               FontSize="12"
                                                               Foreground="#6B7280"
                                                               HorizontalAlignment="Center"/>

                                                    <TextBlock Text="{Binding ExistenciasIniciales}"
                                                               FontSize="20"
                                                               FontWeight="Bold"
                                                               Foreground="#064E3B"
                                                               HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="#DCFCE7"
                                                    CornerRadius="16"
                                                    Padding="18,12"
                                                    MinWidth="85">
                                                <StackPanel>
                                                    <TextBlock Text="Cambio"
                                                               FontSize="12"
                                                               Foreground="#047857"
                                                               HorizontalAlignment="Center"/>

                                                    <TextBlock Text="{Binding ExistenciasAgregadas}"
                                                               FontSize="20"
                                                               FontWeight="Bold"
                                                               Foreground="#16A34A"
                                                               HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="#BBF7D0"
                                                    CornerRadius="16"
                                                    Padding="18,12"
                                                    MinWidth="85">
                                                <StackPanel>
                                                    <TextBlock Text="Final"
                                                               FontSize="12"
                                                               Foreground="#047857"
                                                               HorizontalAlignment="Center"/>

                                                    <TextBlock Text="{Binding ExistenciasFinales}"
                                                               FontSize="20"
                                                               FontWeight="Bold"
                                                               Foreground="#065F46"
                                                               HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>