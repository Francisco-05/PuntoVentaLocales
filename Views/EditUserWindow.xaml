<Window
    x:Class="PuntoVenta.Views.EditUserWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Modificar Usuario">

    <Grid>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#143B73" Offset="0"/>
                <GradientStop Color="#1C2456" Offset="0.5"/>
                <GradientStop Color="#F59AA0" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border Width="850"
                Height="650"
                Background="#22000000"
                CornerRadius="30"
                Padding="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel Spacing="18">

                <TextBlock Text="Modificar Usuario"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBox x:Name="UsernameBox"
                         PlaceholderText="Username"/>

                <PasswordBox x:Name="PasswordBox"
                             PlaceholderText="Password"/>

                <TextBox x:Name="NameBox"
                         PlaceholderText="Nombre"/>

                <TextBox x:Name="PhoneBox"
                         MaxLength="10"
                         PlaceholderText="Teléfono"/>

                <ComboBox x:Name="RoleBox">

                    <ComboBoxItem Content="Empleado"/>

                </ComboBox>

                <Button Content="Guardar Cambios"
                        Height="50"
                        Background="#2563EB"
                        Foreground="White"
                        Click="Save_Click"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>