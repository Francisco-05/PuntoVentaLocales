<Window
    x:Class="PuntoVenta.Views.EditUserWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Modificar Usuario">

    <Grid>
        <!-- Fondo oscuro degradado -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2F3542" Offset="0.00"/>
                <GradientStop Color="#1F2937" Offset="0.45"/>
                <GradientStop Color="#111827" Offset="1.00"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Luces decorativas -->
        <Canvas>
            <Ellipse Width="420"
                     Height="420"
                     Fill="#1838BDF8"
                     Canvas.Left="-120"
                     Canvas.Top="-90"/>

            <Ellipse Width="360"
                     Height="360"
                     Fill="#2022D3EE"
                     Canvas.Left="870"
                     Canvas.Top="90"/>

            <Ellipse Width="260"
                     Height="260"
                     Fill="#18FFFFFF"
                     Canvas.Left="520"
                     Canvas.Top="420"/>
        </Canvas>

        <!-- Tarjeta principal -->
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center">

            <Border Width="560"
                    Height="560"
                    Background="#55FFFFFF"
                    CornerRadius="28"
                    BorderBrush="#B8FFFFFF"
                    BorderThickness="1.5"
                    Padding="35"
                    Margin="0,45,0,0">

                <StackPanel Spacing="15"
                            VerticalAlignment="Center">

                    <TextBlock Text="Modificar Usuario"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,10"/>

                    <!-- Username -->
                    <Border CornerRadius="16"
                            Background="#E9EEF5"
                            Height="46">
                        <TextBox x:Name="UsernameBox"
                                 PlaceholderText="Username"
                                 MaxLength="30"
                                 Background="Transparent"
                                 Height="22"
                                 MaxWidth="450"
                                 Padding="35,0,14,0"
                                 BorderThickness="0"
                                 FontSize="15"
                                 VerticalContentAlignment="Center"/>
                    </Border>

                    <!-- Password -->
                    <Border CornerRadius="16"
                            Background="#E9EEF5"
                            Height="46">
                        <PasswordBox x:Name="PasswordBox"
                                     PlaceholderText="Password"
                                     MaxLength="30"
                                     Background="Transparent"
                                     Height="22"
                                     MaxWidth="450"
                                     Padding="35,0,14,0"
                                     BorderThickness="0"
                                     FontSize="15"
                                     VerticalContentAlignment="Center"/>
                    </Border>

                    <!-- Nombre -->
                    <Border CornerRadius="16"
                            Background="#E9EEF5"
                            Height="46">
                        <TextBox x:Name="NameBox"
                                 PlaceholderText="Nombre"
                                 MaxLength="50"
                                 Background="Transparent"
                                 Height="22"
                                 MaxWidth="450"
                                 Padding="35,0,14,0"
                                 BorderThickness="0"
                                 FontSize="15"
                                 VerticalContentAlignment="Center"/>
                    </Border>

                    <!-- Teléfono -->
                    <Border CornerRadius="16"
                            Background="#E9EEF5"
                            Height="46"
                            Padding="10,0">
                        <TextBox x:Name="PhoneBox"
                                 PlaceholderText="Teléfono"
                                 MaxLength="10"
                                 Background="Transparent"
                                 Height="22"
                                 MaxWidth="450"
                                 Padding="35,0,14,0"
                                 BorderThickness="0"
                                 FontSize="15"
                                 VerticalContentAlignment="Center"/>
                    </Border>

                    <!-- Rol -->
                    <Border CornerRadius="16"
                            Background="#E9EEF5"
                            Height="46">
                        <ComboBox x:Name="RoleBox"
                                  Background="Transparent"
                                  Height="42"
                                  MaxWidth="450"
                                  Padding="35,0,14,0"
                                  BorderThickness="0"
                                  FontSize="15"
                                  HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Empleado"/>
                        </ComboBox>
                    </Border>

                    <!-- Botón guardar -->
                    <Button Content="Guardar Cambios"
                            Width="230"
                            Height="48"
                            Background="#0EA5E9"
                            Foreground="White"
                            FontSize="15"
                            FontWeight="SemiBold"
                            CornerRadius="16"
                            HorizontalAlignment="Center"
                            Margin="0,15,0,0"
                            Click="Save_Click"/>

                </StackPanel>
            </Border>

            <!-- Icono circular arriba -->
            <Grid Width="110"
                  Height="110"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Top">

                <Ellipse Fill="#38BDF8"
                         Stroke="#AEEBFF"
                         StrokeThickness="3"/>

                <FontIcon Glyph="&#xE77B;"
                          FontFamily="Segoe MDL2 Assets"
                          FontSize="48"
                          Foreground="White"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
            </Grid>
        </Grid>
    </Grid>
</Window>