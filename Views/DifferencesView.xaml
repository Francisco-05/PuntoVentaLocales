<Page
    x:Class="PuntoVenta.Views.DifferencesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:PuntoVenta.Helpers">

    <Page.Resources>
        <helpers:CurrencyConverter x:Key="CurrencyConverter"/>
    </Page.Resources>

    <Grid Padding="20" Background="#F5F6FA">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <TextBlock Text="Reporte de diferencias de caja"
                       FontSize="22"
                       FontWeight="Bold"/>

            <Button Content="Volver"
                    HorizontalAlignment="Right"
                    Background="#EF4444"
                    Foreground="White"
                    Click="Back_Click"/>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="15" Margin="0,15,0,10">

            <StackPanel>
                <TextBlock Text="Desde"/>
                <DatePicker x:Name="StartDate"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Hasta"/>
                <DatePicker x:Name="EndDate"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Empleado"/>
                <ComboBox x:Name="EmployeeFilter" Width="200"/>
            </StackPanel>

            <StackPanel VerticalAlignment="Bottom">
                <Button Content="Filtrar"
                        Background="#2563EB"
                        Foreground="White"
                        Click="Filter_Click"/>
            </StackPanel>

        </StackPanel>

        <ListView x:Name="DifferencesList"
                  Grid.Row="2"
                  Margin="0,10,0,0">

            <ListView.ItemTemplate>
                <DataTemplate>

                    <Border Padding="12"
                            Margin="5"
                            Background="White"
                            CornerRadius="10">

                        <StackPanel Spacing="5">

                            <TextBlock Text="{Binding Empleado}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Fecha}"/>

                            <TextBlock Text="{Binding InicioSesion}" FontSize="12" Foreground="Gray"/>
                            <TextBlock Text="{Binding FinSesion}" FontSize="12" Foreground="Gray"/>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="Sistema:" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding EfectivoSistema, Converter={StaticResource CurrencyConverter}}"/>

                                <TextBlock Text="Fisico:" Margin="10,0,0,0" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding EfectivoReal, Converter={StaticResource CurrencyConverter}}"/>
                            </StackPanel>

                            <TextBlock FontWeight="Bold">
                                <Run Text="Diferencia: "/>
                                <Run Text="{Binding Diferencia, Converter={StaticResource CurrencyConverter}}"/>
                            </TextBlock>

                        </StackPanel>

                    </Border>

                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>

    </Grid>
</Page>