<Page
    x:Class="PuntoVenta.Views.DifferencesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:PuntoVenta.Helpers">

    <Page.Resources>
        <helpers:CurrencyConverter x:Key="CurrencyConverter"/>
    </Page.Resources>

    <Grid>
        <!-- Fondo degradado -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#E8B28E" Offset="0.0"/>
                <GradientStop Color="#EEA95D" Offset="0.45"/>
                <GradientStop Color="#F2A13B" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Figuras decorativas -->
        <Canvas>
            <Ellipse Width="260"
                     Height="260"
                     Fill="#25FFFFFF"
                     Canvas.Left="-60"
                     Canvas.Top="-20"/>

            <Ellipse Width="240"
                     Height="240"
                     Fill="#18FFD7B8"
                     Canvas.Left="1080"
                     Canvas.Top="40"/>

            <Ellipse Width="180"
                     Height="180"
                     Fill="#15FFFFFF"
                     Canvas.Left="140"
                     Canvas.Top="560"/>
        </Canvas>

        <!-- Contenedor general -->
        <Grid Padding="35">

            <!-- Tarjeta principal -->
            <Border Background="#F8F8F8"
                    CornerRadius="26"
                    BorderBrush="#E8C6A7"
                    BorderThickness="1.5"
                    Padding="28"
                    VerticalAlignment="Top">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Encabezado -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Reporte de diferencias de caja"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="#1F1F1F"/>

                            <TextBlock Text="Consulta las diferencias entre efectivo del sistema y efectivo físico"
                                       FontSize="14"
                                       Foreground="#666666"
                                       Margin="0,5,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Volver"
                                Background="#E74C3C"
                                Foreground="White"
                                Padding="22,10"
                                FontWeight="SemiBold"
                                Click="Back_Click"
                                VerticalAlignment="Top"/>
                    </Grid>

                    <!-- Filtros -->
                    <Border Grid.Row="1"
                            Margin="0,24,0,18"
                            Background="#F2E4D7"
                            CornerRadius="20"
                            Padding="18">

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Desde -->
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="Desde"
                                           FontWeight="SemiBold"
                                           Foreground="#4A4A4A"/>
                                <Border Background="White"
                                        CornerRadius="14"
                                        Padding="10,4">
                                    <CalendarDatePicker x:Name="StartDate"
                                        Background="Transparent"
                                        BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Hasta -->
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="Hasta"
                                           FontWeight="SemiBold"
                                           Foreground="#4A4A4A"/>
                                <Border Background="White"
                                        CornerRadius="14"
                                        Padding="10,4">
                                    <CalendarDatePicker x:Name="EndDate"
                                         Background="Transparent"
                                         BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Empleado -->
                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="Empleado"
                                           FontWeight="SemiBold"
                                           Foreground="#4A4A4A"/>
                                <Border Background="White"
                                        CornerRadius="14"
                                        Padding="10,2">
                                    <ComboBox x:Name="EmployeeFilter"
                                              Width="200"
                                              Background="Transparent"
                                              BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Botón -->
                            <StackPanel Grid.Column="3"
                                        VerticalAlignment="Bottom">
                                <Button Content="Filtrar"
                                        Background="#2F6BFF"
                                        Foreground="White"
                                        Padding="24,12"
                                        FontWeight="SemiBold"
                                        Click="Filter_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Lista en cuadritos -->
                    <ListView x:Name="DifferencesList"
                          Grid.Row="2"
                          Background="Transparent"
                          BorderThickness="0"
                          Margin="0,18,0,0">

                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal"
                                    MaximumRowsOrColumns="5"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="VerticalContentAlignment" Value="Top"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,16,20"/>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                    CornerRadius="18"
                                    Padding="14"
                                    Width="225"
                                    Height="205"
                                    BorderBrush="#E8D7C8"
                                    BorderThickness="1">

                                    <StackPanel Spacing="7">

                                        <!-- Empleado -->
                                        <TextBlock Text="{Binding Empleado}"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           Foreground="#222222"
                                           TextTrimming="CharacterEllipsis"/>

                                        <!-- Fecha -->
                                        <TextBlock Text="{Binding Fecha}"
                                           FontSize="12"
                                           Foreground="#444444"
                                           TextTrimming="CharacterEllipsis"/>

                                        <!-- Horarios -->
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding InicioSesion}"
                                               FontSize="12"
                                               Foreground="Gray"
                                               TextTrimming="CharacterEllipsis"/>

                                            <TextBlock Text="{Binding FinSesion}"
                                               FontSize="12"
                                               Foreground="Gray"
                                               TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Montos -->
                                        <StackPanel Spacing="4"
                                           Margin="0,6,0,0">

                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="Sistema:"
                                                   FontWeight="SemiBold"
                                                   Foreground="#333333"/>

                                                <TextBlock Text="{Binding EfectivoSistema, Converter={StaticResource CurrencyConverter}}"
                                                   Foreground="#2F6BFF"
                                                   FontWeight="Bold"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="Físico:"
                                                   FontWeight="SemiBold"
                                                   Foreground="#333333"/>

                                                <TextBlock Text="{Binding EfectivoReal, Converter={StaticResource CurrencyConverter}}"
                                                   Foreground="#00A86B"
                                                   FontWeight="Bold"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Diferencia -->
                                        <Border Background="#FFF2E8"
                                            CornerRadius="12"
                                            Padding="10"
                                            Margin="0,6,0,0">

                                            <TextBlock FontSize="14"
                                                FontWeight="Bold"
                                                Foreground="#1F1F1F"
                                                TextTrimming="CharacterEllipsis">
                                                <Run Text="Diferencia: "/>
                                                <Run Text="{Binding Diferencia, Converter={StaticResource CurrencyConverter}}"/>
                                            </TextBlock>
                                        </Border>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>