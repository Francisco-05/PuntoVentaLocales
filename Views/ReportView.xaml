<Page
    x:Class="PuntoVenta.Views.ReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:PuntoVenta.Helpers">

    <Page.Resources>
        <helpers:CurrencyConverter x:Key="CurrencyConverter"/>
        <helpers:DateConverter x:Key="DateConverter"/>
    </Page.Resources>

    <Grid>
        <!-- Fondo degradado -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#5F6676" Offset="0.00"/>
                <GradientStop Color="#7A6A78" Offset="0.30"/>
                <GradientStop Color="#9C8795" Offset="0.58"/>
                <GradientStop Color="#B9AAA9" Offset="0.80"/>
                <GradientStop Color="#D5CBC7" Offset="1.00"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Efectos decorativos -->
        <Canvas>
            <Ellipse Width="420"
                     Height="420"
                     Fill="#25FFFFFF"
                     Canvas.Left="-120"
                     Canvas.Top="-80"/>

            <Ellipse Width="350"
                     Height="350"
                     Fill="#18F2DDE1"
                     Canvas.Left="900"
                     Canvas.Top="-40"/>

            <Ellipse Width="280"
                     Height="280"
                     Fill="#18C7A6B5"
                     Canvas.Left="1080"
                     Canvas.Top="500"/>

            <Ellipse Width="260"
                     Height="260"
                     Fill="#15FFFFFF"
                     Canvas.Left="120"
                     Canvas.Top="520"/>
        </Canvas>

        <!-- Tarjeta principal -->
        <Grid Padding="35">
            <Border Background="#2CFFFFFF"
                    CornerRadius="28"
                    BorderBrush="#50FFFFFF"
                    BorderThickness="1.2"
                    Padding="28">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Encabezado -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Reporte de Ventas"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock Text="Consulta ventas, utilidad y movimientos por empleado"
                                       FontSize="14"
                                       Foreground="#EDEDED"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Salir"
                                Click="Logout_Click"
                                Background="#D9485F"
                                Foreground="White"
                                Padding="22,10"
                                MinWidth="110"
                                FontWeight="SemiBold"
                                VerticalAlignment="Top"/>
                    </Grid>

                    <!-- Filtros -->
                    <Border Grid.Row="1"
                            Margin="0,24,0,18"
                            Background="#20FFFFFF"
                            CornerRadius="22"
                            Padding="20">

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="190"/>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Desde -->
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="Desde"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                                <Border Background="#F7F7F7"
                                        CornerRadius="16"
                                        Padding="10,4">
                                    <CalendarDatePicker x:Name="StartDate"
                                                        Background="Transparent"
                                                        BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Hasta -->
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="Hasta"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                                <Border Background="#F7F7F7"
                                        CornerRadius="16"
                                        Padding="10,4">
                                    <CalendarDatePicker x:Name="EndDate"
                                                        Background="Transparent"
                                                        BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Empleado -->
                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="Empleado"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                                <Border Background="#F7F7F7"
                                        CornerRadius="16"
                                        Padding="10,2">
                                    <ComboBox x:Name="EmployeeFilter"
                                              Width="200"
                                              Background="Transparent"
                                              BorderThickness="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Botón filtrar -->
                            <StackPanel Grid.Column="3"
                                        VerticalAlignment="Bottom">
                                <Button Content="Filtrar"
                                        Click="Filter_Click"
                                        Background="#7E5BEF"
                                        Foreground="White"
                                        Padding="24,12"
                                        FontWeight="SemiBold"/>
                            </StackPanel>

                            <Border Grid.Column="4"
                                Background="#18FFFFFF"
                                CornerRadius="18"
                                Padding="16,10"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom">

                                <TextBlock x:Name="TotalUtilidadText"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="DarkCyan"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Lista de ventas en cuadritos -->
                    <ListView x:Name="SalesList"
                      Grid.Row="2"
                      Background="Transparent"
                      BorderThickness="0"
                      Margin="0,10,0,10"
                      HorizontalAlignment="Stretch">

                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal"
                                     MaximumRowsOrColumns="4"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="VerticalContentAlignment" Value="Top"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,18,20"/>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#EDE6EA"
                                    CornerRadius="22"
                                    Padding="16"
                                    Width="280"
                                    Height="auto"
                                    BorderBrush="#35FFFFFF"
                                    BorderThickness="1">

                                    <StackPanel Spacing="8">

                                        <!-- Fecha -->
                                        <TextBlock Text="{Binding Fecha, Converter={StaticResource DateConverter}}"
                                             FontSize="12"
                                             Foreground="#6B6B6B"/>

                                        <!-- Empleado -->
                                        <TextBlock Text="{Binding Empleado}"
                                            FontSize="20"
                                            FontWeight="Bold"
                                            Foreground="#2F2230"
                                            TextTrimming="CharacterEllipsis"/>

                                        <!-- Productos -->
                                        <TextBlock Text="Productos:"
                                            FontWeight="SemiBold"
                                            Foreground="#4A4A4A"/>

                                        <ScrollViewer 
                                            VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Height="70">

                                            <ItemsControl ItemsSource="{Binding Details}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal"
                                                                Spacing="5"
                                                                Margin="6,0,0,0">

                                                            <TextBlock Text="•"
                                                               Foreground="#3F3F3F"/>

                                                            <TextBlock Text="{Binding Nombre}"
                                                               Foreground="#3F3F3F"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxLines="1"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        </ScrollViewer>



                                        <!-- Totales -->
                                        <StackPanel Margin="0,10,0,0"
                                            Spacing="4">
                                            <StackPanel Orientation="Horizontal"
                                                Spacing="6">

                                                <TextBlock Text="Metodo de Pago: "
                                                    FontWeight="SemiBold"
                                                    Foreground="#333333"/>

                                                <TextBlock Text="{Binding MetodoPago}"
                                                    Foreground="BlueViolet"
                                                    FontWeight="Bold"
                                                     FontSize="14"/>
                                                    
                                            </StackPanel>


                                            <StackPanel Orientation="Horizontal"
                                                Spacing="6">
                                                
                                                <TextBlock Text="Total:"
                                                    FontWeight="SemiBold"
                                                    Foreground="#333333"/>

                                                <TextBlock Text="{Binding TotalBruto, Converter={StaticResource CurrencyConverter}}"
                                                    Foreground="#2F6BFF"
                                                    FontWeight="Bold"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal"
                                                 Spacing="6">
                                                <TextBlock Text="Utilidad:"
                                                     FontWeight="SemiBold"
                                                     Foreground="#333333"/>

                                                <TextBlock Text="{Binding Utilidad, Converter={StaticResource CurrencyConverter}}"
                                                    Foreground="#00A86B"
                                                    FontWeight="Bold"/>
                                            </StackPanel>

                                        </StackPanel>

                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Total ventas -->
                    <Border Grid.Row="3"
                            Background="#18FFFFFF"
                            CornerRadius="18"
                            Padding="14"
                            HorizontalAlignment="Right">
                        <TextBlock x:Name="TotalVentasText"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="DarkCyan"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>