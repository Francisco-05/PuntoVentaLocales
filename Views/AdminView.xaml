<Page x:Class="PuntoVenta.Views.AdminView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1B120F"
      Loaded="Page_Loaded">

    <Grid>

        <!-- Fondo elegante café/dorado -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1B120F" Offset="0"/>
                <GradientStop Color="#3A241A" Offset="0.45"/>
                <GradientStop Color="#8B5E34" Offset="0.78"/>
                <GradientStop Color="#D6A75A" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Líneas decorativas -->
        <Canvas Opacity="0.18">
            <Line X1="0"
                  Y1="120"
                  X2="1920"
                  Y2="120"
                  Stroke="#F5E6C8"
                  StrokeThickness="2"/>

            <Line X1="330"
                  Y1="0"
                  X2="330"
                  Y2="1080"
                  Stroke="#E0B56C"
                  StrokeThickness="1"/>

            <Line X1="0"
                  Y1="720"
                  X2="1920"
                  Y2="720"
                  Stroke="#F2D7A6"
                  StrokeThickness="1"/>

            <Line X1="0"
                  Y1="0"
                  X2="1920"
                  Y2="1080"
                  Stroke="#F5E6C8"
                  StrokeThickness="2"/>
        </Canvas>

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Padding="40"
                        Spacing="40"
                        HorizontalAlignment="Center">

                <!-- TÍTULO -->
                <StackPanel HorizontalAlignment="Center">

                    <TextBlock Text="INICIO ADMINISTRATIVO"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="#FFF7E8"
                               HorizontalAlignment="Center"
                               FontFamily="Segoe UI"/>
                </StackPanel>

                <!-- BIENVENIDA -->
                <Border Background="#3B2A24"
                        CornerRadius="20"
                        Padding="20"
                        Width="1200"
                        Opacity="0.92"
                        BorderBrush="#D6A75A"
                        BorderThickness="1.5">

                    <TextBlock Text="Bienvenido(a) Administrador"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#FFF7E8"/>
                </Border>

                <!-- GRID BOTONES -->
                <Grid RowSpacing="35"
                      ColumnSpacing="35"
                      HorizontalAlignment="Center">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- EMPLEADOS -->
                    <Button x:Name="BtnEmpleados"
                            Grid.Row="0"
                            Grid.Column="0"
                            Content="👤 Crear Empleado"
                            Width="320"
                            Height="170"
                            Background="#2A1A14"
                            Foreground="#FFF7E8"
                            FontSize="22"
                            FontWeight="Bold"
                            CornerRadius="25"
                            BorderBrush="#D6A75A"
                            BorderThickness="2"
                            Click="CreateUser_Click"
                            Opacity="0">

                        <Button.RenderTransform>
                            <TranslateTransform Y="60"/>
                        </Button.RenderTransform>

                    </Button>

                    <!-- PRODUCTOS -->
                    <Button x:Name="BtnProductos"
                            Grid.Row="0"
                            Grid.Column="1"
                            Content="🛍️ Crear Productos"
                            Width="320"
                            Height="170"
                            Background="#3A241A"
                            Foreground="#FFF7E8"
                            FontSize="22"
                            FontWeight="Bold"
                            CornerRadius="25"
                            BorderBrush="#E0B56C"
                            BorderThickness="2"
                            Click="CreateProduct_Click"
                            Opacity="0">

                        <Button.RenderTransform>
                            <TranslateTransform Y="60"/>
                        </Button.RenderTransform>

                    </Button>

                    <!-- REPORTES -->
                    <Button x:Name="BtnReportes"
                            Grid.Row="0"
                            Grid.Column="2"
                            Content="📊 Ver Reportes Ventas"
                            Width="320"
                            Height="170"
                            Background="#4A2E1F"
                            Foreground="#FFF7E8"
                            FontSize="22"
                            FontWeight="Bold"
                            CornerRadius="25"
                            BorderBrush="#F2D7A6"
                            BorderThickness="2"
                            Click="ReportView_Click"
                            Opacity="0">

                        <Button.RenderTransform>
                            <TranslateTransform Y="60"/>
                        </Button.RenderTransform>

                    </Button>

                    <!-- DIFERENCIAS -->
                    <Button x:Name="BtnDiferencias"
                            Grid.Row="1"
                            Grid.Column="0"
                            Content="💲 Ver Reporte De Diferencias"
                            Width="Auto"
                            Height="170"
                            Background="#5A3424"
                            Foreground="#FFF7E8"
                            FontSize="22"
                            FontWeight="Bold"
                            CornerRadius="25"
                            BorderBrush="#D6A75A"
                            BorderThickness="2"
                            Click="DifView_Click"
                            Opacity="0">

                        <Button.RenderTransform>
                            <TranslateTransform Y="60"/>
                        </Button.RenderTransform>

                    </Button>

                    <!-- REGISTRO -->
                    <Button x:Name="BtnRegistroProductos"
                            Grid.Row="1"
                            Grid.Column="1"
                            Content="📝 Usuarios y Productos"
                            Width="320"
                            Height="170"
                            Background="#6B3F27"
                            Foreground="#FFF7E8"
                            FontSize="22"
                            FontWeight="Bold"
                            CornerRadius="25"
                            BorderBrush="#E0B56C"
                            BorderThickness="2"
                            Click="ProductRegistry_Click"
                            Opacity="0">

                        <Button.RenderTransform>
                            <TranslateTransform Y="60"/>
                        </Button.RenderTransform>

                    </Button>

                    <!-- REABASTECIMIENTO -->
                    <Button x:Name="BtnRestockReport"
                            Grid.Row="1"
                            Grid.Column="2"
                            Content="📥 Ver Reporte De Existencia"
                            Width="320"
                            Height="170"
                            Background="#7A4A2A"
                            Foreground="#FFF7E8"
                            FontSize="22"
                            FontWeight="Bold"
                            CornerRadius="25"
                            BorderBrush="#F2D7A6"
                            BorderThickness="2"
                            Click="RestockReport_Click"
                            Opacity="0">

                        <Button.RenderTransform>
                            <TranslateTransform Y="60"/>
                        </Button.RenderTransform>

                    </Button>

                </Grid>

                <!-- BOTÓN CERRAR SESIÓN -->
                <Button x:Name="BtnCerrarSesion"
                        Content="↩️ Cerrar sesión"
                        Width="260"
                        Height="55"
                        Background="#2A1A14"
                        Foreground="#FFF7E8"
                        FontWeight="Bold"
                        FontSize="16"
                        CornerRadius="25"
                        BorderBrush="#D6A75A"
                        BorderThickness="2"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,30"
                        Click="Logout_Click"
                        Opacity="0">

                    <Button.RenderTransform>
                        <TranslateTransform Y="40"/>
                    </Button.RenderTransform>

                </Button>

            </StackPanel>

        </ScrollViewer>

    </Grid>
</Page>
