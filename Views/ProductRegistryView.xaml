<Page
    x:Class="PuntoVenta.Views.ProductRegistryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:PuntoVenta.Helpers">

    <Page.Resources>
        <helpers:CurrencyConverter x:Key="CurrencyConverter"/>
    </Page.Resources>

    <Grid Padding="20" Background="#F5F6FA">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Registro de productos"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    Content="Volver"
                    Background="#EF4444"
                    Foreground="White"
                    CornerRadius="4"
                    Click="Back_Click"
                    VerticalAlignment="Center"
                    MinWidth="100"/>
        </Grid>

        <ScrollViewer Grid.Row="1" Margin="0,20,0,0" HorizontalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="#1F1F1F" BorderBrush="#2D2D2D" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="380"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                        </Grid.RowDefinitions>

                        <Border BorderBrush="#2D2D2D" BorderThickness="0,0,1,0" Padding="8,0" VerticalAlignment="Center">
                            <TextBlock Text="ID" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="1" BorderBrush="#2D2D2D" BorderThickness="0,0,1,0" Padding="8,0" VerticalAlignment="Center">
                            <TextBlock Text="NOMBRE" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="2" BorderBrush="#2D2D2D" BorderThickness="0,0,1,0" Padding="8,0" VerticalAlignment="Center">
                            <TextBlock Text="MARCA" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="3" BorderBrush="#2D2D2D" BorderThickness="0,0,1,0" Padding="8,0" VerticalAlignment="Center">
                            <TextBlock Text="DESCRIPCION" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="4" BorderBrush="#2D2D2D" BorderThickness="0,0,1,0" Padding="8,0" VerticalAlignment="Center">
                            <TextBlock Text="COSTO" FontWeight="SemiBold" Foreground="White" TextAlignment="Right" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="5" BorderBrush="#2D2D2D" BorderThickness="0,0,1,0" Padding="8,0" VerticalAlignment="Center">
                            <TextBlock Text="PRECIO VENTA" FontWeight="SemiBold" Foreground="White" TextAlignment="Right" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="6" BorderBrush="#2D2D2D" BorderThickness="0,0,1,0" Padding="8,0" VerticalAlignment="Center">
                            <TextBlock Text="EXISTENCIAS" FontWeight="SemiBold" Foreground="White" TextAlignment="Right" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="7" BorderBrush="#2D2D2D" BorderThickness="0,0,0,0" Padding="8,0" VerticalAlignment="Center">
                            <TextBlock Text="ACCIONES" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <ItemsControl x:Name="ProductsList" Grid.Row="1">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2B2B2B" BorderBrush="#2D2D2D" BorderThickness="1,0,1,1">
                                <Grid Height="32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="380"/>
                                    </Grid.ColumnDefinitions>

                                    <Border BorderBrush="#3A3A3A" BorderThickness="0,0,1,0" Padding="8,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Id}" Foreground="White" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="1" BorderBrush="#3A3A3A" BorderThickness="0,0,1,0" Padding="8,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Nombre}" Foreground="White" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    <Border Grid.Column="2" BorderBrush="#3A3A3A" BorderThickness="0,0,1,0" Padding="8,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Marca}" Foreground="White" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    <Border Grid.Column="3" BorderBrush="#3A3A3A" BorderThickness="0,0,1,0" Padding="8,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Descripcion}" Foreground="White" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    <Border Grid.Column="4" BorderBrush="#3A3A3A" BorderThickness="0,0,1,0" Padding="8,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Costo, Converter={StaticResource CurrencyConverter}}" TextAlignment="Right" Foreground="White" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="5" BorderBrush="#3A3A3A" BorderThickness="0,0,1,0" Padding="8,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding PrecioVenta, Converter={StaticResource CurrencyConverter}}" TextAlignment="Right" Foreground="White" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="6" BorderBrush="#3A3A3A" BorderThickness="0,0,1,0" Padding="8,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Existencias}" TextAlignment="Right" Foreground="White" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="7" BorderBrush="#3A3A3A" BorderThickness="0,0,0,0" Padding="4" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Button Content="Modificar" 
                                                    Background="#2563EB" 
                                                    Foreground="White"
                                                    FontSize="12"
                                                    Padding="8,4"
                                                    CornerRadius="4"
                                                    MinWidth="80"
                                                    Click="Modify_Click"/>
                                            <Button Content="Reabastecimiento" 
                                                    Background="#10B981" 
                                                    Foreground="White"
                                                    FontSize="12"
                                                    Padding="8,4"
                                                    CornerRadius="4"
                                                    MinWidth="90"
                                                    Click="Restock_Click"/>
                                            <Button Content="Eliminar"
                                                    Background="#EF4444"
                                                    Foreground="White"
                                                    FontSize="12"
                                                    Padding="8,4"
                                                    CornerRadius="4"
                                                    MinWidth="80"
                                                    Click="Delete_Click"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
