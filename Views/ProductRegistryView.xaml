<Page
    x:Class="PuntoVenta.Views.ProductRegistryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:PuntoVenta.Helpers">

    <Page.Resources>
        <helpers:CurrencyConverter x:Key="CurrencyConverter"/>
    </Page.Resources>

    <Grid>
        <!-- Fondo tipo oscuro / blur -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#111827" Offset="0.00"/>
                <GradientStop Color="#1E293B" Offset="0.35"/>
                <GradientStop Color="#334155" Offset="0.65"/>
                <GradientStop Color="#0F172A" Offset="1.00"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Figuras decorativas -->
        <Canvas>
            <Ellipse Width="430"
                     Height="430"
                     Fill="#182563EB"
                     Canvas.Left="-120"
                     Canvas.Top="-100"/>

            <Ellipse Width="380"
                     Height="380"
                     Fill="#2238BDF8"
                     Canvas.Left="920"
                     Canvas.Top="20"/>

            <Ellipse Width="300"
                     Height="300"
                     Fill="#1822C55E"
                     Canvas.Left="140"
                     Canvas.Top="500"/>

            <Ellipse Width="300"
                     Height="300"
                     Fill="#15FFFFFF"
                     Canvas.Left="520"
                     Canvas.Top="150"/>
        </Canvas>

        <Grid Padding="35">
            <Border Background="#38FFFFFF"
                    CornerRadius="28"
                    BorderBrush="#55FFFFFF"
                    BorderThickness="1"
                    Padding="28">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Encabezado -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Registro de productos"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock Text="Consulta, modifica y administra el inventario registrado"
                                       FontSize="14"
                                       Foreground="#DCE7F5"
                                       Margin="0,5,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Volver"
                                Background="#EF4444"
                                Foreground="White"
                                Padding="24,11"
                                FontWeight="SemiBold"
                                Click="Back_Click"
                                VerticalAlignment="Top"
                                MinWidth="110"/>
                    </Grid>

                    <!-- Tabla -->
                    <ScrollViewer Grid.Row="1"
                                  Margin="0,28,0,0"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Encabezado tabla -->
                            <Border Background="#202A3A"
                                    CornerRadius="18,18,0,0"
                                    BorderBrush="#3B4658"
                                    BorderThickness="1">

                                <Grid Height="48">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="250"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="390"/>
                                    </Grid.ColumnDefinitions>

                                    <Border BorderBrush="#334155" BorderThickness="0,0,1,0" Padding="10,0">
                                        <TextBlock Text="ID" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    </Border>

                                    <Border Grid.Column="1" BorderBrush="#334155" BorderThickness="0,0,1,0" Padding="10,0">
                                        <TextBlock Text="NOMBRE" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    </Border>

                                    <Border Grid.Column="2" BorderBrush="#334155" BorderThickness="0,0,1,0" Padding="10,0">
                                        <TextBlock Text="MARCA" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    </Border>

                                    <Border Grid.Column="3" BorderBrush="#334155" BorderThickness="0,0,1,0" Padding="10,0">
                                        <TextBlock Text="DESCRIPCIÓN" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    </Border>

                                    <Border Grid.Column="4" BorderBrush="#334155" BorderThickness="0,0,1,0" Padding="10,0">
                                        <TextBlock Text="COSTO" FontWeight="SemiBold" Foreground="White" TextAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <Border Grid.Column="5" BorderBrush="#334155" BorderThickness="0,0,1,0" Padding="10,0">
                                        <TextBlock Text="PRECIO VENTA" FontWeight="SemiBold" Foreground="White" TextAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <Border Grid.Column="6" BorderBrush="#334155" BorderThickness="0,0,1,0" Padding="10,0">
                                        <TextBlock Text="EXISTENCIAS" FontWeight="SemiBold" Foreground="White" TextAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <Border Grid.Column="7" Padding="10,0">
                                        <TextBlock Text="ACCIONES" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Filas -->
                            <ItemsControl x:Name="ProductsList" Grid.Row="1">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#EEF3FA"
                                                BorderBrush="#D7DEE8"
                                                BorderThickness="1,0,1,1">

                                            <Grid Height="44">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="160"/>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="250"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="390"/>
                                                </Grid.ColumnDefinitions>

                                                <Border BorderBrush="#D7DEE8" BorderThickness="0,0,1,0" Padding="10,0">
                                                    <TextBlock Text="{Binding Id}"
                                                               Foreground="#111827"
                                                               VerticalAlignment="Center"/>
                                                </Border>

                                                <Border Grid.Column="1" BorderBrush="#D7DEE8" BorderThickness="0,0,1,0" Padding="10,0">
                                                    <TextBlock Text="{Binding Nombre}"
                                                               Foreground="#111827"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </Border>

                                                <Border Grid.Column="2" BorderBrush="#D7DEE8" BorderThickness="0,0,1,0" Padding="10,0">
                                                    <TextBlock Text="{Binding Marca}"
                                                               Foreground="#111827"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </Border>

                                                <Border Grid.Column="3" BorderBrush="#D7DEE8" BorderThickness="0,0,1,0" Padding="10,0">
                                                    <TextBlock Text="{Binding Descripcion}"
                                                               Foreground="#111827"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </Border>

                                                <Border Grid.Column="4" BorderBrush="#D7DEE8" BorderThickness="0,0,1,0" Padding="10,0">
                                                    <TextBlock Text="{Binding Costo, Converter={StaticResource CurrencyConverter}}"
                                                               TextAlignment="Right"
                                                               Foreground="#111827"
                                                               VerticalAlignment="Center"/>
                                                </Border>

                                                <Border Grid.Column="5" BorderBrush="#D7DEE8" BorderThickness="0,0,1,0" Padding="10,0">
                                                    <TextBlock Text="{Binding PrecioVenta, Converter={StaticResource CurrencyConverter}}"
                                                               TextAlignment="Right"
                                                               Foreground="#2563EB"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                </Border>

                                                <Border Grid.Column="6" BorderBrush="#D7DEE8" BorderThickness="0,0,1,0" Padding="10,0">
                                                    <TextBlock Text="{Binding Existencias}"
                                                               TextAlignment="Right"
                                                               Foreground="#059669"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                </Border>

                                                <Border Grid.Column="7" Padding="6" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="7">

                                                        <Button Content="Modificar"
                                                                Background="#2563EB"
                                                                Foreground="White"
                                                                FontSize="12"
                                                                Padding="10,4"
                                                                MinWidth="84"
                                                                Click="Modify_Click"/>

                                                        <Button Content="Reabastecimiento"
                                                                Background="#10B981"
                                                                Foreground="White"
                                                                FontSize="12"
                                                                Padding="10,4"
                                                                MinWidth="118"
                                                                Click="Restock_Click"/>

                                                        <Button Content="Eliminar"
                                                                Background="#EF4444"
                                                                Foreground="White"
                                                                FontSize="12"
                                                                Padding="10,4"
                                                                MinWidth="84"
                                                                Click="Delete_Click"/>

                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
