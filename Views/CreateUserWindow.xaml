<Window
    x:Class="PuntoVenta.Views.CreateUserWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F5F6FA">

        <Border Width="450"
                Padding="25"
                Background="White"
                CornerRadius="12"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel Spacing="12">

                <TextBlock Text="Crear Usuario"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <TextBox x:Name="UsernameBox" PlaceholderText="Username" Height="40"/>
                <PasswordBox x:Name="PasswordBox" PlaceholderText="Password" Height="40"/>
                <TextBox x:Name="NameBox" PlaceholderText="Nombre completo" Height="40"/>
                <TextBox x:Name="PhoneBox" PlaceholderText="Teléfono" Height="40" MaxLength="10" BeforeTextChanging="PhoneBox_BeforeTextChanging"/>

                <DatePicker x:Name="BirthDatePicker"/>

                <ComboBox x:Name="RoleBox">
                    <ComboBoxItem Content="Empleado"/>
                </ComboBox>

                <Button Content="Guardar Usuario"
                        Background="#4F46E5"
                        Foreground="White"
                        Height="40"
                        Click="Save_Click"/>

            </StackPanel>
        </Border>

    </Grid>
</Window>