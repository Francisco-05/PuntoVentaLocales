<Window
    x:Class="PuntoVenta.Views.CreateUserWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Crear Usuario">

    <Grid>
        <!-- Fondo degradado -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#143B73" Offset="0.0"/>
                <GradientStop Color="#1C2456" Offset="0.55"/>
                <GradientStop Color="#F59AA0" Offset="0.85"/>
                <GradientStop Color="#FFD38B" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Tarjeta principal -->
        <Border Width="950"
                Height="760"
                Background="#22000000"
                CornerRadius="35"
                BorderBrush="#40FFFFFF"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="0">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="290"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Lado izquierdo -->
                <Grid Grid.Column="0" Background="#15000000">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="20">

                        <!-- Círculo del usuario -->
                        <Grid Width="150" Height="150">
                            <Ellipse Fill="#55FFFFFF"/>
                            <FontIcon Glyph="&#xE77B;"
                                      FontFamily="Segoe MDL2 Assets"
                                      FontSize="72"
                                      Foreground="White"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="Nuevo Usuario"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Completa la información"
                                   FontSize="16"
                                   Foreground="#D9FFFFFF"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Lado derecho -->
                <Grid Grid.Column="1" Padding="45">
                    <StackPanel VerticalAlignment="Center" Spacing="18">

                        <TextBlock Text="Crear Usuario"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,10"/>

                        <!-- Username -->
                        <Border CornerRadius="22"
                                Background="#E9ECF4"
                                BorderBrush="#2D4A9A"
                                BorderThickness="1.5"
                                Height="52">
                            <TextBox x:Name="UsernameBox"
                                     PlaceholderText="Username"
                                     MaxLength="30"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Height="25"
                                     MaxWidth="540"
                                     Padding="35,0"
                                     FontSize="16"
                                     VerticalContentAlignment="Center"/>
                        </Border>

                        <!-- Password -->
                        <Border CornerRadius="22"
                                Background="#E9ECF4"
                                BorderBrush="#2D4A9A"
                                BorderThickness="1.5"
                                Height="52">
                            <PasswordBox x:Name="PasswordBox"
                                         PlaceholderText="Password"
                                         MaxLength="30"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Height="25"
                                         MaxWidth="540"
                                         Padding="35,0"
                                         FontSize="16"/>
                        </Border>

                        <!-- Nombre -->
                        <Border CornerRadius="22"
                                Background="#E9ECF4"
                                BorderBrush="#2D4A9A"
                                BorderThickness="1.5"
                                Height="52">
                            <TextBox x:Name="NameBox"
                                     PlaceholderText="Nombre completo"
                                     MaxLength="50"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Height="25"
                                     MaxWidth="540"
                                     Padding="35,0"
                                     FontSize="16"
                                     VerticalContentAlignment="Center"/>
                        </Border>

                        <!-- Teléfono -->
                        <Border CornerRadius="22"
                                Background="#E9ECF4"
                                BorderBrush="#2D4A9A"
                                BorderThickness="1.5"
                                Height="52">
                            <TextBox x:Name="PhoneBox"
                                     PlaceholderText="Teléfono"
                                     MaxLength="10"
                                     BeforeTextChanging="PhoneBox_BeforeTextChanging"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Height="25"
                                     MaxWidth="540"
                                     Padding="35,0"
                                     FontSize="16"
                                     VerticalContentAlignment="Center"/>
                        </Border>

                        <!-- Fecha -->
                        <Border CornerRadius="22"
                                Background="#E9ECF4"
                                BorderBrush="#2D4A9A"
                                BorderThickness="1.5"
                                Height="52"
                                Padding="10,0">
                            <CalendarDatePicker x:Name="BirthDatePicker"
                                                PlaceholderText="Fecha de nacimiento"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                MaxWidth="540"
                                                FontSize="16"
                                                HorizontalAlignment="Stretch"/>
                        </Border>

                        <!-- Rol -->
                        <Border CornerRadius="22"
                                Background="#E9ECF4"
                                BorderBrush="#2D4A9A"
                                BorderThickness="1.5"
                                Height="52"
                                Padding="10,0">
                            <ComboBox x:Name="RoleBox"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Height="Auto"
                                      FontSize="16"
                                      MaxWidth="540"
                                      Padding="12,12,12,12"
                                      HorizontalAlignment="Stretch"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Empleado"
                                              />
                            </ComboBox>
                        </Border>

                        <!-- Botón -->
                        <Button Content="Guardar Usuario"
                                Height="52"
                                Width="250"
                                HorizontalAlignment="Left"
                                Margin="0,12,0,0"
                                Background="#2B2E55"
                                Foreground="White"
                                FontSize="18"
                                FontWeight="SemiBold"
                                CornerRadius="22"
                                Click="Save_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>