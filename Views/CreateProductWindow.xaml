<Window
    x:Class="PuntoVenta.Views.CreateProductWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F5F6FA">

        <Border Width="450"
                Padding="25"
                Background="White"
                CornerRadius="12"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel Spacing="12">

                <TextBlock Text="Agregar Producto"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <TextBox x:Name="NameBox" PlaceholderText="Nombre" Height="40"/>
                <TextBox x:Name="BrandBox" PlaceholderText="Marca" Height="40"/>
                <TextBox x:Name="DescBox" PlaceholderText="Descripción" Height="40" />

                <TextBox x:Name="CostBox" PlaceholderText="Costo" Height="40" BeforeTextChanging="OnlyNumbersDecimal_BeforeTextChanging"/>
                <TextBox x:Name="PriceBox" PlaceholderText="Precio venta (con IVA)" Height="40" BeforeTextChanging="OnlyNumbersDecimal_BeforeTextChanging"/>

                <StackPanel Spacing="8">

                    <TextBox x:Name="ImageBox"
             PlaceholderText="Imagen seleccionada"
             Height="40"
             IsReadOnly="True"/>

                    <Button Content="Seleccionar Imagen"
            Height="40"
            Background="#6366F1"
            Foreground="White"
            Click="SelectImage_Click"/>

                </StackPanel>

                <Button Content="Guardar Producto"
                        Background="#10B981"
                        Foreground="White"
                        Height="40"
                        Click="Save_Click"/>

            </StackPanel>
        </Border>

    </Grid>
</Window>