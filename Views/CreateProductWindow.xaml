<Window
    x:Class="PuntoVenta.Views.CreateProductWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Agregar Producto">

    <Grid>
        <!-- Fondo -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#5B1232" Offset="0.00"/>
                <GradientStop Color="#8B1638" Offset="0.25"/>
                <GradientStop Color="#C71F2D" Offset="0.55"/>
                <GradientStop Color="#A45A3A" Offset="0.82"/>
                <GradientStop Color="#6A4A5D" Offset="1.00"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Efectos decorativos -->
        <Canvas>
            <Ellipse Width="420"
                     Height="420"
                     Fill="#33FF3B30"
                     Canvas.Left="720"
                     Canvas.Top="-80"/>

            <Ellipse Width="360"
                     Height="360"
                     Fill="#224B1E78"
                     Canvas.Left="-100"
                     Canvas.Top="360"/>

            <Ellipse Width="300"
                     Height="300"
                     Fill="#22FFB36B"
                     Canvas.Left="980"
                     Canvas.Top="420"/>

            <Ellipse Width="300"
                     Height="300"
                     Fill="#22A00040"
                     Canvas.Left="120"
                     Canvas.Top="40"/>
        </Canvas>

        <!-- Tarjeta principal -->
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center">

            <Border Width="950"
                    Height="560"
                    Background="#EFD6DB"
                    CornerRadius="28"
                    Padding="0">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Lado izquierdo -->
                    <Grid Grid.Column="0" Background="#00000000">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="18">

                            <!-- Circulo con icono -->
                            <Grid Width="140" Height="140">
                                <Ellipse Fill="#C62839"/>
                                <FontIcon Glyph="&#xE7BF;"
                                          FontFamily="Segoe MDL2 Assets"
                                          FontSize="60"
                                          Foreground="White"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="Nuevo Producto"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#7A1227"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Captura la información del producto"
                                       FontSize="13"
                                       Foreground="#7A1227"
                                       TextAlignment="Center"
                                       Width="230"/>
                        </StackPanel>
                    </Grid>

                    <!-- Lado derecho -->
                    <Grid Grid.Column="1" Padding="40">
                        <StackPanel VerticalAlignment="Center"
                                    Spacing="10">

                            <TextBlock Text="Agregar Producto"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="#7A1227"
                                       Margin="0,0,0,8"/>

                            <!-- Nombre -->
                            <Border CornerRadius="18"
                                    Background="#F8F8F8"
                                    Height="48">
                                <TextBox x:Name="NameBox"
                                         PlaceholderText="Nombre"
                                         MaxLength="50"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Height="26"
                                         MaxWidth="570"
                                         Padding="14,0"
                                         FontSize="16"
                                         VerticalContentAlignment="Center"/>
                            </Border>

                            <!-- Marca -->
                            <Border CornerRadius="18"
                                    Background="#F8F8F8"
                                    Height="48">
                                <TextBox x:Name="BrandBox"
                                         PlaceholderText="Marca"
                                         MaxLength="20"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Height="26"
                                         MaxWidth="570"
                                         Padding="14,0"
                                         FontSize="16"
                                         VerticalContentAlignment="Center"/>
                            </Border>

                            <!-- Descripción -->
                            <Border CornerRadius="18"
                                    Background="#F8F8F8"
                                    Height="48">
                                <TextBox x:Name="DescBox"
                                         PlaceholderText="Descripción"
                                         MaxLength="200"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Height="26"
                                         MaxWidth="570"
                                         Padding="14,0"
                                         FontSize="16"
                                         VerticalContentAlignment="Center"/>
                            </Border>

                            <!-- Costo -->
                            <Border CornerRadius="18"
                                    Background="#F8F8F8"
                                    Height="48">
                                <TextBox x:Name="CostBox"
                                         PlaceholderText="Costo"
                                         BeforeTextChanging="OnlyNumbersDecimal_BeforeTextChanging"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Height="26"
                                         MaxWidth="570"
                                         Padding="14,0"
                                         FontSize="16"
                                         VerticalContentAlignment="Center"/>
                            </Border>

                            <!-- Precio -->
                            <Border CornerRadius="18"
                                    Background="#F8F8F8"
                                    Height="48">
                                <TextBox x:Name="PriceBox"
                                         PlaceholderText="Precio venta (con IVA)"
                                         BeforeTextChanging="OnlyNumbersDecimal_BeforeTextChanging"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Height="26"
                                         MaxWidth="570"
                                         Padding="14,0"
                                         FontSize="16"
                                         VerticalContentAlignment="Center"/>
                            </Border>

                            <!-- Imagen -->
                            <Border CornerRadius="18"
                                    Background="#F8F8F8"
                                    Height="48">
                                <TextBox x:Name="ImageBox"
                                         PlaceholderText="Imagen seleccionada"
                                         IsReadOnly="True"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Height="26"
                                         MaxWidth="570"
                                         Padding="14,0"
                                         FontSize="16"
                                         VerticalContentAlignment="Center"/>
                            </Border>

                            <!-- Botones -->
                            <StackPanel Orientation="Horizontal"
                                        Spacing="16"
                                        Margin="0,14,0,0"
                                        HorizontalAlignment="Left">

                                <Button Content="Seleccionar Imagen"
                                        Width="200"
                                        Height="44"
                                        Background="#C62839"
                                        Foreground="White"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        CornerRadius="14"
                                        Click="SelectImage_Click"/>

                                <Button Content="Guardar Producto"
                                        Width="200"
                                        Height="44"
                                        Background="#8B1638"
                                        Foreground="White"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        CornerRadius="14"
                                        Click="Save_Click"/>

                            </StackPanel>

                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>