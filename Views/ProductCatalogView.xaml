<Page
    x:Class="PuntoVenta.Views.ProductCatalogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:PuntoVenta.Helpers">

    <Page.Resources>
        <helpers:CurrencyConverter x:Key="CurrencyConverter"/>
    </Page.Resources>

    <Grid Background="#F5F6FA">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

 
        <Grid Background="#1F2937" Padding="10">
            <TextBlock x:Name="UserText"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Right"/>
            
            <Button Content="Cerrar sesión"
                    Width="200"
                    Height="45"
                    Background="#EF4444"
                    Foreground="White"
                    CornerRadius="8"
                    Click="Logout_Click"/>
        </Grid>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0">
                <ItemsControl x:Name="ProductsList">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapGrid />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border Margin="10"
                                    Padding="10"
                                    Background="White"
                                    CornerRadius="12"
                                    Width="200">

                                <StackPanel Spacing="8">

                                    <Image Source="{Binding Imagen}"
                                           Height="120"
                                           Stretch="UniformToFill"/>

                                    <TextBlock Text="{Binding Nombre}"
                                               FontWeight="Bold"/>

                                    <TextBlock Text="{Binding Marca}"
                                               Foreground="Gray"/>

                                    <TextBlock Text="{Binding PrecioVenta, Converter={StaticResource CurrencyConverter}}"
                                               Foreground="Green"
                                               FontWeight="SemiBold"/>

                                    <Button Content="Agregar"
                                            Click="AddToCart_Click"
                                            Background="#10B981"
                                            Foreground="White"/>

                                </StackPanel>

                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>
            </ScrollViewer>

            <Grid Grid.Column="1" Background="White" Padding="10">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Carrito"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <ListView x:Name="CartList"
                          Grid.Row="1">

                    <ListView.ItemTemplate>
                        <DataTemplate>

                            <Grid Margin="5">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding Nombre}"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Text="{Binding PrecioUnitario, Converter={StaticResource CurrencyConverter}}"
                                               Foreground="Gray"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="5"
                                            VerticalAlignment="Center">

                                    <Button Content="-" Width="30" Click="Decrease_Click"/>

                                    <TextBlock Text="{Binding Cantidad}"
                                               Width="30"
                                               TextAlignment="Center"/>

                                    <Button Content="+" Width="30" Click="Increase_Click"/>

                                </StackPanel>

                            </Grid>

                        </DataTemplate>
                    </ListView.ItemTemplate>

                </ListView>

                <StackPanel Grid.Row="2" Margin="0,10,0,0">

                    <TextBlock x:Name="TotalText"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <Button Content="Confirmar compra"
                            Background="#2563EB"
                            Foreground="White"
                            Height="40"
                            Click="ConfirmSale_Click"/>
                </StackPanel>

            </Grid>

        </Grid>

    </Grid>
</Page>