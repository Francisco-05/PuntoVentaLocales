<Page
    x:Class="PuntoVenta.Views.ProductCatalogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:PuntoVenta.Helpers">

    <Page.Resources>
        <helpers:CurrencyConverter x:Key="CurrencyConverter"/>
    </Page.Resources>

    <Grid Background="#F5F6FA">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Background="#1F2937" Padding="10">
            <TextBlock x:Name="UserText"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"/>

            <Button Content="Cortar Caja"
                    Width="200"
                    Height="45"
                    Background="#EF4444"
                    Foreground="White"
                    CornerRadius="8"
                    Click="CashCut_Click"/>
        </Grid>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- PRODUCTOS -->
            <Grid Grid.Column="0">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0">
                    <ItemsControl x:Name="ProductsList">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapGrid Orientation="Horizontal"
                                          MaximumRowsOrColumns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <Border Margin="10"
                                        Padding="10"
                                        Background="White"
                                        BorderBrush="#D1D5DB"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Width="200"
                                        Height="260">

                                    <StackPanel Spacing="6">

                                        <Image Source="{Binding Imagen}"
                                               Height="110"
                                               Stretch="UniformToFill"/>

                                        <TextBlock Text="{Binding Nombre}"
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock Text="{Binding Marca}"
                                                   Foreground="Gray"/>

                                        <TextBlock Text="{Binding PrecioVenta, Converter={StaticResource CurrencyConverter}}"
                                                   Foreground="#10B981"
                                                   FontWeight="SemiBold"/>

                                        <Button Content="Agregar"
                                                Height="32"
                                                Click="AddToCart_Click"
                                                Background="#10B981"
                                                Foreground="White"
                                                CornerRadius="6"/>

                                    </StackPanel>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                </ScrollViewer>

                <!-- PAGINACIÓN -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="40"
                            Margin="0,10">

                    <Button x:Name="PreviousPageButton"
                            Content="&lt;"
                            Width="45"
                            Height="45"
                            FontSize="20"
                            CornerRadius="25"
                            Click="PreviousPage_Click"/>

                    <Button x:Name="NextPageButton"
                            Content="&gt;"
                            Width="45"
                            Height="45"
                            FontSize="20"
                            CornerRadius="25"
                            Click="NextPage_Click"/>
                </StackPanel>

            </Grid>

            <!-- CARRITO -->
            <Grid Grid.Column="1"
                  Background="White"
                  Padding="10">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Carrito"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>


                <ListView x:Name="CartList"
                          Grid.Row="1"
                          HorizontalContentAlignment="Stretch">

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>

                            <Grid Margin="6"
                                  HorizontalAlignment="Stretch">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>

                                <!-- PRODUCTO -->
                                <StackPanel Grid.Column="0"
                                            VerticalAlignment="Center">

                                    <TextBlock Text="{Binding Nombre}"
                                               FontWeight="SemiBold"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Text="{Binding PrecioUnitario, Converter={StaticResource CurrencyConverter}}"
                                               Foreground="Gray"/>
                                </StackPanel>

                                <!-- MENOS -->
                                <Button Grid.Column="1"
                                        Content="-"
                                        Width="30"
                                        Height="30"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Click="Decrease_Click"/>

                                <!-- CANTIDAD -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Cantidad}"
                                           Width="30"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"/>

                                <!-- MÁS -->
                                <Button Grid.Column="3"
                                        Content="+"
                                        Width="30"
                                        Height="30"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Click="Increase_Click"/>

                            </Grid>

                        </DataTemplate>
                    </ListView.ItemTemplate>

                </ListView>

                <StackPanel Grid.Row="2"
                            Margin="0,10,0,0">

                    <TextBlock x:Name="TotalText"
                               Text="Total: $0.00"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <Button Content="Confirmar compra"
                            Background="#2563EB"
                            Foreground="White"
                            Height="40"
                            CornerRadius="6"
                            Click="ConfirmSale_Click"/>
                </StackPanel>

            </Grid>

        </Grid>

    </Grid>
</Page>