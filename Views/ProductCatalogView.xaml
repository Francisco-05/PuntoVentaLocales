<Page
    x:Class="PuntoVenta.Views.ProductCatalogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:PuntoVenta.Helpers">

    <Page.Resources>
        <helpers:CurrencyConverter x:Key="CurrencyConverter"/>
    </Page.Resources>

    <Grid>

        <!-- Fondo -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1B120F" Offset="0"/>
                <GradientStop Color="#3A241A" Offset="0.45"/>
                <GradientStop Color="#8B5E34" Offset="0.78"/>
                <GradientStop Color="#D6A75A" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Decoración -->
        <Canvas Opacity="0.16">

            <Line X1="0" Y1="120"
                  X2="1920" Y2="120"
                  Stroke="#F5E6C8"
                  StrokeThickness="2"/>

            <Line X1="330" Y1="0"
                  X2="330" Y2="1080"
                  Stroke="#E0B56C"
                  StrokeThickness="1"/>

            <Line X1="0" Y1="0"
                  X2="1920" Y2="1080"
                  Stroke="#F5E6C8"
                  StrokeThickness="2"/>

            <Ellipse Width="420"
                     Height="420"
                     Fill="#18F5E6C8"
                     Canvas.Left="-130"
                     Canvas.Top="-90"/>

            <Ellipse Width="360"
                     Height="360"
                     Fill="#20D6A75A"
                     Canvas.Left="930"
                     Canvas.Top="70"/>

        </Canvas>

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barra superior -->
            <Border Background="#2A1A14"
                    Padding="18"
                    BorderBrush="#D6A75A"
                    BorderThickness="0,0,0,1.5">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Usuario -->
                    <TextBlock x:Name="UserText"
                               Grid.Column="0"
                               Foreground="#FFF7E8"
                               FontSize="15"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,25,0"/>

                    <!-- Reloj -->
                    <TextBlock x:Name="ClockText"
                               Grid.Column="1"
                               Foreground="#FFF7E8"
                               FontSize="18"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>

                    <!-- Botón -->
                    <Button Grid.Column="3"
                            Content="Cortar Caja"
                            Width="210"
                            Height="48"
                            Background="#7A2E2E"
                            Foreground="#FFF7E8"
                            FontWeight="SemiBold"
                            CornerRadius="18"
                            Click="CashCut_Click"/>

                </Grid>

            </Border>

            <!-- Contenido -->
            <Grid Grid.Row="1"
                  Padding="17"
                  ColumnSpacing="25">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- PRODUCTOS -->
                <Border Grid.Column="0"
                        Background="#35FFF7E8"
                        CornerRadius="28"
                        BorderBrush="#D6A75A"
                        BorderThickness="1.5"
                        Padding="20">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Margin="0,0,0,15">

                            <TextBlock Text="Productos disponibles"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="#FFF7E8"/>

                            <TextBlock Text="Selecciona productos para agregarlos al carrito"
                                       Foreground="#F2D7A6"
                                       FontSize="14"/>

                        </StackPanel>

                        <!-- Productos -->
                        <Grid Grid.Row="1">

                            <ItemsControl x:Name="ProductsList"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">

                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapGrid Orientation="Horizontal"
                                                  MaximumRowsOrColumns="3"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>

                                    <DataTemplate>

                                        <Border Width="190"
                                                Height="240"
                                                Margin="4"
                                                Padding="8"
                                                Background="#FFF7E8"
                                                BorderBrush="#D6A75A"
                                                BorderThickness="1.5"
                                                CornerRadius="16">

                                            <Grid>

                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="85"/>
                                                    <RowDefinition Height="42"/>
                                                    <RowDefinition Height="22"/>
                                                    <RowDefinition Height="28"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="40"/>
                                                </Grid.RowDefinitions>

                                                <!-- Imagen -->
                                                <Border Grid.Row="0"
                                                        Background="#F5E6C8"
                                                        CornerRadius="12"
                                                        Margin="0,0,0,8">

                                                    <Image Source="{Binding Imagen}"
                                                           Stretch="Uniform"
                                                           MaxHeight="72"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>

                                                </Border>

                                                <!-- Nombre -->
                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding Nombre}"
                                                           FontWeight="Bold"
                                                           FontSize="13"
                                                           Foreground="#1B120F"
                                                           TextWrapping="Wrap"
                                                           MaxLines="2"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Top"/>

                                                <!-- Marca -->
                                                <TextBlock Grid.Row="2"
                                                           Text="{Binding Marca}"
                                                           Foreground="#6B4A32"
                                                           FontSize="11"
                                                           Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <!-- Precio -->
                                                <TextBlock Grid.Row="3"
                                                           Text="{Binding PrecioVenta, Converter={StaticResource CurrencyConverter}}"
                                                           Foreground="#8B5E34"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           Margin="0,2,0,0"/>

                                                <!-- Botón -->
                                                <Button Grid.Row="5"
                                                        Content="Agregar"
                                                        Width="95"
                                                        Height="35"
                                                        Background="#8B5E34"
                                                        Foreground="#FFF7E8"
                                                        FontWeight="SemiBold"
                                                        CornerRadius="12"
                                                        HorizontalAlignment="Left"
                                                        Click="AddToCart_Click"
                                                        Loaded="AgregarButton_Loaded"/>

                                            </Grid>

                                        </Border>

                                    </DataTemplate>

                                </ItemsControl.ItemTemplate>

                            </ItemsControl>

                        </Grid>

                        <!-- Paginación -->
                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="40"
                                    Margin="0,15,0,0">

                            <Button x:Name="PreviousPageButton"
                                    Content="&lt;"
                                    Width="48"
                                    Height="48"
                                    FontSize="20"
                                    Background="#F5E6C8"
                                    Foreground="#3A241A"
                                    FontWeight="Bold"
                                    CornerRadius="25"
                                    Click="PreviousPage_Click"/>

                            <Button x:Name="NextPageButton"
                                    Content="&gt;"
                                    Width="48"
                                    Height="48"
                                    FontSize="20"
                                    Background="#F5E6C8"
                                    Foreground="#3A241A"
                                    FontWeight="Bold"
                                    CornerRadius="25"
                                    Click="NextPage_Click"/>

                        </StackPanel>

                    </Grid>

                </Border>

                <!-- CARRITO -->
                <Border Grid.Column="1"
                        Background="#FFF7E8"
                        CornerRadius="28"
                        BorderBrush="#D6A75A"
                        BorderThickness="1.5"
                        Padding="22">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,0,0,15">

                            <TextBlock Text="Carrito"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="#1B120F"/>

                            <TextBlock Text="Resumen de compra"
                                       FontSize="14"
                                       Foreground="#6B4A32"/>

                        </StackPanel>

                        <ListView x:Name="CartList"
                                  Grid.Row="1"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  HorizontalContentAlignment="Stretch">

                            <ListView.ItemContainerStyle>

                                <Style TargetType="ListViewItem">

                                    <Setter Property="HorizontalContentAlignment"
                                            Value="Stretch"/>

                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,10"/>

                                </Style>

                            </ListView.ItemContainerStyle>

                            <ListView.ItemTemplate>

                                <DataTemplate>

                                    <Border Background="White"
                                            CornerRadius="18"
                                            Padding="12"
                                            BorderBrush="#E0B56C"
                                            BorderThickness="1">

                                        <Grid HorizontalAlignment="Stretch">

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0"
                                                        VerticalAlignment="Center">

                                                <TextBlock Text="{Binding Nombre}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#1B120F"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <TextBlock Text="{Binding PrecioUnitario, Converter={StaticResource CurrencyConverter}}"
                                                           Foreground="#8B5E34"
                                                           FontWeight="SemiBold"/>

                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                    Content="-"
                                                    Width="32"
                                                    Height="32"
                                                    Margin="-6,0,0,0"
                                                    Background="#F5E6C8"
                                                    Foreground="#3A241A"
                                                    FontWeight="Bold"
                                                    CornerRadius="16"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Click="Decrease_Click"/>

                                            <TextBox Grid.Column="2"
                                                     Text="{Binding Cantidad, Mode=TwoWay}"
                                                     Width="36"
                                                 
                                                     Height="32"
                                                     Padding="0,4,0,0"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     TextAlignment="Center"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     VerticalContentAlignment="Center"
                                                     FontWeight="Bold"
                                                     FontSize="15"
                                                     Foreground="#1B120F"
                                                     BeforeTextChanging="Cantidad_BeforeTextChanging"
                                                     LostFocus="Cantidad_LostFocus"/>

                                            <Button Grid.Column="3"
                                                    Content="+"
                                                    Width="32"
                                                    Height="32"
                                                    Margin="-6,0,0,0"
                                                    Background="#8B5E34"
                                                    Foreground="#FFF7E8"
                                                    FontWeight="Bold"
                                                    CornerRadius="16"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Click="Increase_Click"/>

                                        </Grid>

                                    </Border>

                                </DataTemplate>

                            </ListView.ItemTemplate>

                        </ListView>

                        <!-- Total -->
                        <Border Grid.Row="2"
                                Background="#2A1A14"
                                CornerRadius="22"
                                Padding="18"
                                Margin="0,15,0,0"
                                BorderBrush="#D6A75A"
                                BorderThickness="1.5">

                            <StackPanel>

                                <TextBlock x:Name="TotalText"
                                           Text="Total: $0.00"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#FFF7E8"
                                           Margin="0,0,0,12"/>

                                <Button Content="Confirmar compra"
                                        Background="#D6A75A"
                                        Foreground="#1B120F"
                                        Height="45"
                                        FontWeight="Bold"
                                        CornerRadius="16"
                                        Click="ConfirmSale_Click"/>

                            </StackPanel>

                        </Border>

                    </Grid>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</Page>